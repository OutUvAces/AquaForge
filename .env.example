# Copy to .env and fill in your Copernicus Data Space account.
# https://dataspace.copernicus.eu/
COPERNICUS_USERNAME=your-email@example.com
COPERNICUS_PASSWORD=your-password

# Required for full-resolution L2A downloads (TCI_10m JP2) and wake analysis/diagrams.
# Create keys at https://eodata-s3keysmanager.dataspace.copernicus.eu/ — not the same as the password above.
COPERNICUS_S3_ACCESS_KEY=
COPERNICUS_S3_SECRET_KEY=
